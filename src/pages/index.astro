---
import Layout from '../layouts/Layout.astro';
import parties from '../data/parties.json';
---

<Layout
  title="Lasi viegli | Saeimas vēlēšanu 2026 sarakstu programmas vieglajā valodā"
  description="2026. gada Saeimas vēlēšanu visu 14 kandidātu sarakstu programmas vieglajā valodā, ar iespēju salīdzināt ar oriģinālo tekstu."
>
  <div class="wrap">
    <section class="hero">
      <span class="eyebrow">2026. gada 15. Saeimas vēlēšanas</span>
      <h1>Sarakstu programmas, kuras var izlasīt un saprast ikviens</h1>
      <div class="lede">
        <p>Šogad Latvijā ir Saeimas vēlēšanas. Vēlēšanās piedalās 14 kandidātu saraksti.</p>
        <p>Katram sarakstam ir programma. Tā apraksta, ko šī saraksta kandidāti sola darīt.</p>
        <p>
          Mēs katru programmu pārrakstījām <strong>vieglajā valodā</strong>.
          Vieglā valoda ir īsi teikumi un saprotami vārdi.
        </p>
      </div>
      <div class="actions">
        <a class="btn primary" href="#saraksti">Izvēlēties sarakstu</a>
        <a class="btn secondary" href="/par-projektu/">Kā mēs to izdarījām?</a>
      </div>
    </section>

    <section class="how-to" aria-labelledby="how-to-title">
      <h2 id="how-to-title">Kā lasīt programmas?</h2>
      <div class="steps">
        <div class="step">
          <span class="n" aria-hidden="true">1</span>
          <p><strong>Izvēlies sarakstu.</strong> Saraksti zemāk ir tādā pašā secībā kā vēlēšanu zīmē.</p>
        </div>
        <div class="step">
          <span class="n" aria-hidden="true">2</span>
          <p><strong>Izlasi programmu</strong> vieglajā valodā. Grūtie vārdi ir paskaidroti.</p>
        </div>
        <div class="step">
          <span class="n" aria-hidden="true">3</span>
          <p><strong>Padomā, kuri jautājumi ir svarīgi tev un tavai ģimenei.</strong> Skaties, ko saraksts par tiem sola.</p>
        </div>
        <div class="step">
          <span class="n" aria-hidden="true">4</span>
          <p><strong>Salīdzini vairākus sarakstus un to oriģinālus.</strong> Blakus cilnē ir saraksta īstais teksts.</p>
        </div>
      </div>
      <p class="how-to-more">
        <a href="/par-projektu/#kas-ir-partijas-programma">Kas ir partijas programma? &rarr;</a>
      </p>
    </section>

    <section class="party-section" id="saraksti">
      <h2>Izvēlies sarakstu</h2>
      <p class="note">Saraksti ir vēlēšanu numuru secībā. Mēs esam neitrāli. Mēs rādām visus sarakstus vienādi. Izvēlies pats.</p>
      <ul class="cards" role="list">
        {
          parties.map((p) => (
            <li class="card">
              <span class="num" aria-hidden="true">{p.n}</span>
              <h3 id={`pname-${p.n}`}>{p.name}</h3>
              <p class="meta">
                Saraksts Nr. {p.n} · {p.candidates} kandidāti · lasīšana ~{p.minutes} min
              </p>
              <a
                class="go"
                id={`go-${p.n}`}
                href={`/saraksti/${p.slug}/`}
                aria-labelledby={`go-${p.n} pname-${p.n}`}
              >
                Lasīt vieglajā valodā
              </a>
            </li>
          ))
        }
      </ul>
    </section>
  </div>
</Layout>
